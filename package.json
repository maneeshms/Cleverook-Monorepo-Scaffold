{
  "name": "clevscaffold",
  "version": "0.1.0",
  "description": "ClevScaffold — Cleverook enterprise project scaffold. Nx monorepo (NestJS backends + React frontends).",
  "author": "Cleverook",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "nx": "nx",
    "init": "node scripts/init.mjs",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "e2e": "nx run-many -t e2e --parallel=1",
    "e2e:setup": "node scripts/e2e-setup.mjs",
    "lint": "nx run-many -t lint",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev:api": "nx serve api",
    "dev:web": "nx dev web",
    "dev:web-next": "nx dev web-next",
    "scan:security": "python3 scripts/security_scan.py",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d libs/database/src/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d libs/database/src/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d libs/database/src/data-source.ts",
    "dev:api-prisma": "nx serve api-prisma",
    "prisma:generate": "prisma generate --schema apps/api-prisma/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/api-prisma/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema apps/api-prisma/prisma/schema.prisma",
    "prisma:seed": "ts-node apps/api-prisma/prisma/seed.ts",
    "prisma:studio": "prisma studio --schema apps/api-prisma/prisma/schema.prisma",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "1.2.0",
    "@nestjs/common": "10.4.22",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.22",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.22",
    "@nestjs/schedule": "4.1.2",
    "@nestjs/swagger": "7.4.2",
    "@nestjs/terminus": "10.3.0",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "10.0.2",
    "@openfeature/server-sdk": "1.22.0",
    "@prisma/client": "6.19.1",
    "bcryptjs": "2.4.3",
    "bullmq": "5.79.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.4",
    "dotenv": "16.6.1",
    "helmet": "8.2.0",
    "ioredis": "5.11.1",
    "nest-winston": "1.10.2",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.22.0",
    "prisma": "6.19.1",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "resend": "6.17.1",
    "rxjs": "7.8.2",
    "typeorm": "0.3.30",
    "uuid": "10.0.0",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@eslint/js": "9.39.4",
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.22",
    "@nx/jest": "20.8.4",
    "@nx/js": "20.8.4",
    "@nx/webpack": "23.0.1",
    "@types/bcryptjs": "2.4.6",
    "@types/express": "5.0.6",
    "@types/jest": "29.5.14",
    "@types/node": "22.20.0",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.3",
    "@types/uuid": "10.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.2",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "15.5.2",
    "nx": "20.8.4",
    "prettier": "3.9.1",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.17",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "webpack-node-externals": "3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
