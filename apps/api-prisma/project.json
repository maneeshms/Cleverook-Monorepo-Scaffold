{
  "name": "api-prisma",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api-prisma/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/api-prisma"],
      "options": {
        "command": "prisma generate --schema apps/api-prisma/prisma/schema.prisma && tsc -p apps/api-prisma/tsconfig.app.json && tsc-alias -p apps/api-prisma/tsconfig.app.json"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node -r tsconfig-paths/register apps/api-prisma/src/main.ts"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "jestConfig": "apps/api-prisma/jest.config.ts"
      }
    },
    "e2e": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "apps/api-prisma/jest.e2e.config.ts",
        "runInBand": true,
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint apps/api-prisma"
      }
    }
  },
  "tags": ["scope:api-prisma", "type:app"]
}
