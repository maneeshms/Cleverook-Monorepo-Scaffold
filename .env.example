# ============================================================================
# ClevScaffold environment template
#
# Configuration is LAYERED (see docs/CONFIGURATION.md). Resolution order:
#   1. process.env               <- always wins (this file / the host / Railway)
#   2. config/{NODE_ENV}.json    <- per-app, per-environment overrides
#   3. config/default.json       <- per-app defaults
#   4. code default              <- last resort inside libs/config
#
# SECRETS (JWT_*, *_API_KEY, DATABASE passwords, ...) belong ONLY here / in the
# host environment — never in the JSON config files. The loader rejects secret
# keys found in JSON.
# ============================================================================

# ── Core ──
# NODE_ENV defaults to 'development' via the config layer. Don't set it in .env:
# Nx exports .env to every task and `next build` requires NODE_ENV=production.
PORT=3000

# clevscaffold:typeorm:start
# ── Database (TypeORM app: apps/api) ──
# Works unchanged against local Docker, self-hosted Postgres, or Supabase:
#   local:              postgresql://postgres:postgres@localhost:5432/clevscaffold
#   Supabase direct:    postgresql://postgres:[PW]@db.[ref].supabase.co:5432/postgres   + DATABASE_SSL=require
#   Supabase pooled:    postgresql://postgres.[ref]:[PW]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_SSL: disable | require | no-verify   (managed hosts usually need require/no-verify)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clevscaffold
DATABASE_SSL=disable
DATABASE_POOL_MAX=20
# clevscaffold:typeorm:end

# clevscaffold:prisma:start
# ── Database (Prisma app: apps/api-prisma) ──
# For Supabase/pgbouncer transaction pooling append ?pgbouncer=true and point
# migrations at the direct (5432) host — see docs/DATABASE.md.
PRISMA_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clevscaffold_prisma
# clevscaffold:prisma:end

# clevscaffold:auth:start
# ── JWT secrets (generate with: openssl rand -base64 48) ──
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string_min_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12
# clevscaffold:auth:end

# ── Security ──
# Comma-separated allowlist in prod (enables credentialed CORS).
# '*' emits a literal wildcard with credentials DISABLED — dev only.
CORS_ORIGINS=*

# ── Rate limiting ──
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ── Redis (optional) ──
# Enables distributed rate limiting + the async messaging delivery queue.
# Leave unset for single-instance dev: throttling stays in-memory, deliveries run inline.
# REDIS_URL=redis://localhost:6379

# clevscaffold:messaging:start
# ── Messaging (libs/messaging) ──
# Omnichannel layer. Without a provider key the EMAIL channel falls back to the
# console-email logger (visible in logs, nothing sent) — no mock data, explicit fallback.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=ClevScaffold
# Force the EMAIL channel provider: 'resend' or 'console-email' (overrides DB route).
MESSAGING_EMAIL_PROVIDER=
# Push notifications (Android + iOS + Web via Firebase Cloud Messaging).
# Paste the Firebase service-account JSON, raw or base64-encoded:
#   base64 < service-account.json | tr -d '\n'
# Empty ⇒ the PUSH channel logs to console-push (explicit fallback, nothing sent).
FCM_SERVICE_ACCOUNT_JSON=
# Force the PUSH channel provider: 'fcm' or 'console-push' (overrides DB route).
MESSAGING_PUSH_PROVIDER=
# clevscaffold:messaging:end

# clevscaffold:featureflags:start
# ── Feature flags (OpenFeature) ──
# Provider backing flag evaluation: 'env' (FF_<KEY> vars) or 'database' (feature_flags table).
# Swap for a hosted provider (LaunchDarkly, Flagsmith, ...) later without touching call sites.
FEATURE_FLAG_PROVIDER=env
FEATURE_FLAG_CACHE_TTL_MS=30000
# Example env-provider flags (only used when FEATURE_FLAG_PROVIDER=env):
# FF_NEW_CHECKOUT=true
# clevscaffold:featureflags:end

# clevscaffold:compliance:start
# ── Compliance (audit trail · GDPR retention) ──
# Dedicated HMAC key for the tamper-evident audit hash chain (falls back to
# JWT_ACCESS_SECRET). Set a distinct value in prod: openssl rand -base64 48
AUDIT_HMAC_SECRET=
# Retention windows in days (0 or less = keep forever). Cron runs daily at 03:00.
RETENTION_AUDIT_LOG_DAYS=365
RETENTION_SOFT_DELETED_USER_DAYS=30
RETENTION_NOTIFICATION_DAYS=180
RETENTION_MESSAGE_DELIVERY_DAYS=90
RETENTION_DEVICE_TOKEN_DAYS=270
RETENTION_CRON=true
# clevscaffold:compliance:end

# clevscaffold:metrics:start
# ── Observability ──
# Prometheus /metrics endpoint (apps/api). Optionally protect with a bearer token.
METRICS_ENABLED=true
METRICS_TOKEN=
# clevscaffold:metrics:end

# ── Logging ──
LOG_LEVEL=info
LOG_DIR=logs
# File logging is opt-in. Default = console-only (good for Railway/containers).
# LOG_TO_FILE=true
